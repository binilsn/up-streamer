<!-- Streaming Control & Filter Toolbar -->
<div data-controller="live-stream" data-live-stream-selected-service-value="<%= params[:service].presence || 'all' %>" class="space-y-6">
  <div class="flex items-center justify-between bg-white border border-[#E2E8F0] rounded-lg px-6 py-3">
    <!-- Left: Stream Status -->
    <div class="flex items-center gap-3">
      <button data-action="click->live-stream#togglePause"
              class="w-8 h-8 flex items-center justify-center bg-surface-container border border-outline-variant rounded hover:bg-surface-container-higher transition-colors">
        <span data-live-stream-target="pauseIcon" class="material-symbols-outlined text-[18px] text-on-surface-variant">pause</span>
      </button>
      <div class="flex items-center gap-2">
        <span data-live-stream-target="indicator" class="w-2 h-2 rounded-full bg-secondary-container animate-pulse"></span>
        <span class="font-body text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider">STREAM ACTIVE</span>
      </div>
      <div data-live-stream-target="pausedIndicator" class="flex items-center gap-2 hidden">
        <span class="w-2 h-2 rounded-full bg-amber-500"></span>
        <span class="font-body text-[12px] font-semibold text-on-surface-variant uppercase tracking-wider">PAUSED</span>
      </div>
    </div>

    <!-- Center: Severity Facet Filter -->
    <div class="flex items-center gap-3">
      <span class="font-body text-[12px] font-medium text-on-surface-variant uppercase tracking-wider">SEVERITY:</span>
      <div data-live-stream-target="filters" class="flex bg-surface-container rounded p-0.5 border border-outline-variant">
        <button class="px-3 py-1.5 bg-white shadow-sm text-on-surface font-body text-[12px] font-medium rounded active" data-level-filter="all">ALL</button>
        <button class="px-3 py-1.5 text-on-surface-variant font-body text-[12px] font-medium hover:text-on-surface transition-colors flex items-center gap-1.5 rounded" data-level-filter="error">
          <span class="w-1.5 h-1.5 rounded-full bg-error"></span>ERROR
        </button>
        <button class="px-3 py-1.5 text-on-surface-variant font-body text-[12px] font-medium hover:text-on-surface transition-colors flex items-center gap-1.5 rounded" data-level-filter="warn">
          <span class="w-1.5 h-1.5 rounded-full bg-amber-600"></span>WARN
        </button>
        <button class="px-3 py-1.5 text-on-surface-variant font-body text-[12px] font-medium hover:text-on-surface transition-colors flex items-center gap-1.5 rounded" data-level-filter="info">
          <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>INFO
        </button>
      </div>
    </div>

    <!-- Right: Max Entries Control & Events Count -->
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-2">
        <span class="font-body text-[12px] text-on-surface-variant font-medium uppercase tracking-wider">MAX:</span>
        <select data-action="change->live-stream#changeMaxEntries"
                class="font-code text-[12px] bg-surface-container border border-outline-variant rounded px-2 py-1.5 text-on-surface focus:outline-none focus:border-secondary">
          <option value="100">100</option>
          <option value="500" selected>500</option>
          <option value="1000">1,000</option>
          <option value="5000">5,000</option>
        </select>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-body text-[12px] text-on-surface-variant font-medium">Events:</span>
        <span data-live-stream-target="count" class="font-code text-[13px] text-on-surface font-semibold">0</span>
      </div>
    </div>
  </div>

  <!-- Live Log Stream Grid -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg overflow-hidden">
    <!-- Column Header -->
    <div class="grid grid-cols-[120px_90px_1fr_2.5fr] gap-4 px-6 py-3 bg-surface-container border-b border-[#E2E8F0]">
      <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">TIMESTAMP</span>
      <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">LEVEL</span>
      <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">SOURCE</span>
      <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">MESSAGE</span>
    </div>

    <!-- Virtual-scrolled Log Entries Container -->
    <div data-live-stream-target="container"
         class="max-h-[calc(100vh-320px)] overflow-y-auto relative">
      <div class="placeholder-text flex items-center justify-center py-12 text-on-surface-variant font-body text-[13px]">
        Waiting for incoming log events...
      </div>
    </div>
  </div>
</div>
