<div data-controller="dashboard">

<!-- A. Dashboard Header Row -->
<div class="flex justify-between items-end mb-6">
  <div>
    <h2 class="font-headline text-[32px] font-bold tracking-tight text-on-surface">System Overview</h2>
    <p class="font-body text-[14px] text-on-surface-variant mt-1">
      Cluster Status: <span class="text-secondary font-semibold">HEALTHY</span>
      <span class="text-on-surface-variant mx-2">|</span>
      124 Active Nodes
    </p>
  </div>
  <div class="flex gap-2">
    <div class="flex bg-surface-container rounded p-1 border border-outline-variant">
      <button class="px-4 py-1.5 bg-white shadow-sm text-on-surface font-body text-[12px] font-medium rounded">LIVE</button>
      <button class="px-4 py-1.5 text-on-surface-variant font-body text-[12px] font-medium">1H</button>
      <button class="px-4 py-1.5 text-on-surface-variant font-body text-[12px] font-medium">24H</button>
    </div>
  </div>
</div>

<!-- B. Analytical Metric Row (6 Cards) -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-6">

  <!-- Card 1: TOTAL_LOGS_24H -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-4">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">TOTAL_LOGS_24H</span>
      <span class="text-secondary-container material-symbols-outlined text-[20px]">monitoring</span>
    </div>
    <div class="font-headline text-[32px] font-bold text-on-surface mb-2">4.2M</div>
    <div class="flex items-center gap-1 font-body text-[12px] text-secondary-container mb-4">
      <span class="material-symbols-outlined text-[16px]">trending_up</span>
      <span>+12.4% vs last period</span>
    </div>
    <div class="h-[3px] bg-[#E2E8F0] w-full overflow-hidden rounded">
      <div class="bg-secondary-container h-full w-[40%] rounded"></div>
    </div>
  </div>

  <!-- Card 2: ERROR_RATE -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-4">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">ERROR_RATE</span>
      <span class="text-error material-symbols-outlined text-[20px]">warning</span>
    </div>
    <div class="font-headline text-[32px] font-bold text-error mb-2">0.42%</div>
    <div class="flex items-center gap-1 font-body text-[12px] text-error mb-4">
      <span class="material-symbols-outlined text-[16px]">trending_up</span>
      <span>+0.05% vs last period</span>
    </div>
    <div class="h-10 flex items-end gap-[3px]">
      <div class="bg-error/20 flex-1 h-[25%] rounded-sm"></div>
      <div class="bg-error/20 flex-1 h-[35%] rounded-sm"></div>
      <div class="bg-error/20 flex-1 h-[50%] rounded-sm"></div>
      <div class="bg-error/40 flex-1 h-[65%] rounded-sm"></div>
      <div class="bg-error/60 flex-1 h-[85%] rounded-sm"></div>
      <div class="bg-error/80 flex-1 h-[70%] rounded-sm"></div>
    </div>
  </div>

  <!-- Card 3: INGESTION RATE (Live) -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-4">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">INGESTION RATE</span>
      <span class="text-secondary material-symbols-outlined text-[20px]">speed</span>
    </div>
    <div class="flex items-baseline gap-1 mb-2">
      <span class="font-headline text-[32px] font-bold text-on-surface" id="metric-ingestion-rate">0.0</span>
      <span class="font-body text-[14px] font-medium text-on-surface-variant">KB/S</span>
    </div>
    <div class="flex items-center gap-1 font-body text-[12px] text-secondary mb-4">
      <span class="w-2 h-2 rounded-full bg-secondary-container animate-pulse"></span>
      <span id="metric-ingestion-rate-label">Streaming</span>
    </div>
    <div class="h-[3px] bg-[#E2E8F0] w-full overflow-hidden rounded">
      <div class="bg-secondary h-full w-[60%] rounded animate-pulse"></div>
    </div>
  </div>

  <!-- Card 4: EVENTS/SEC (Live) -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-4">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">EVENTS/SEC</span>
      <span class="text-secondary-container material-symbols-outlined text-[20px]">pulse</span>
    </div>
    <div class="font-headline text-[32px] font-bold text-on-surface mb-2" id="metric-events-per-sec">0</div>
    <div class="flex items-center gap-1 font-body text-[12px] text-secondary mb-4">
      <span class="w-2 h-2 rounded-full bg-secondary-container animate-pulse"></span>
      <span>Real-time</span>
    </div>
    <div class="h-10 flex items-end gap-[3px]">
      <div class="bg-secondary-container/20 flex-1 h-[25%] rounded-sm" style="height: var(--bar1, 25%)"></div>
      <div class="bg-secondary-container/20 flex-1 h-[35%] rounded-sm" style="height: var(--bar2, 35%)"></div>
      <div class="bg-secondary-container/20 flex-1 h-[50%] rounded-sm" style="height: var(--bar3, 50%)"></div>
      <div class="bg-secondary-container/40 flex-1 h-[65%] rounded-sm" style="height: var(--bar4, 65%)"></div>
      <div class="bg-secondary-container/60 flex-1 h-[85%] rounded-sm" style="height: var(--bar5, 85%)"></div>
      <div class="bg-secondary-container/80 flex-1 h-[70%] rounded-sm" style="height: var(--bar6, 70%)"></div>
    </div>
  </div>

  <!-- Card 5: ACTIVE_ALERTS -->
  <%= link_to alerts_path, class: "block" do %>
    <div class="bg-white border border-[#E2E8F0] rounded-lg p-6 hover:shadow-md transition-shadow">
      <div class="flex justify-between items-start mb-4">
        <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">ACTIVE_ALERTS</span>
        <span class="text-on-surface material-symbols-outlined text-[20px]">notifications_active</span>
      </div>
      <div class="font-headline text-[32px] font-bold text-on-surface mb-2" id="metric-active-alerts"><%= Alert.active.count %></div>
      <div class="flex items-center gap-1 font-body text-[12px] text-on-surface-variant mb-4">
        <span class="material-symbols-outlined text-[16px]">timer</span>
        <span><%= time_ago_in_words(Alert.active.recent.first&.triggered_at || Time.current) %> ago</span>
      </div>
      <div class="flex gap-1">
        <% Alert.active.group(:severity).count.sort_by { |_, c| -c }.each do |sev, count| %>
          <% sev_color = case sev
             when "critical" then "bg-error text-white"
             when "high" then "bg-orange-600 text-white"
             when "medium" then "bg-amber-500 text-white"
             else "bg-surface-container-highest text-on-surface-variant"
             end %>
          <div class="w-7 h-7 rounded-full border-2 border-white <%= sev_color %> text-[10px] flex items-center justify-center font-bold shadow-sm" title="<%= count %> <%= sev %>">
            <%= count %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Card 6: SYS_LATENCY_P99 -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-4">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">SYS_LATENCY_P99</span>
      <span class="text-secondary material-symbols-outlined text-[20px]">bolt</span>
    </div>
    <div class="font-headline text-[32px] font-bold text-on-surface mb-2">42ms</div>
    <div class="flex items-center gap-1 font-body text-[12px] text-secondary mb-4">
      <span class="material-symbols-outlined text-[16px]">trending_down</span>
      <span>-4ms vs baseline</span>
    </div>
    <div class="h-10 flex items-end gap-[3px]">
      <div class="flex-1 bg-secondary/30 h-[45%] rounded-sm"></div>
      <div class="flex-1 bg-secondary/30 h-[60%] rounded-sm"></div>
      <div class="flex-1 bg-secondary/30 h-[45%] rounded-sm"></div>
      <div class="flex-1 bg-secondary/50 h-[70%] rounded-sm"></div>
      <div class="flex-1 bg-secondary/60 h-[45%] rounded-sm"></div>
      <div class="flex-1 bg-secondary/80 h-[45%] rounded-sm"></div>
    </div>
  </div>
</div>

<!-- C. Primary Graphic Container (Log Volume) -->
<div class="bg-white border border-[#E2E8F0] rounded-lg p-6 min-h-[400px] flex flex-col">
  <div class="flex justify-between items-start mb-6">
    <div>
      <h3 class="font-headline text-[20px] font-semibold text-on-surface">Real-Time Ingestion Rate</h3>
      <p class="font-body text-[12px] text-on-surface-variant mt-1">Live throughput from streaming ingestion</p>
    </div>
  </div>
  <div class="flex-1 relative" style="min-height:300px">
    <canvas data-controller="log-volume-chart" style="width:100%;height:100%;display:block"></canvas>
  </div>
</div>

</div>
