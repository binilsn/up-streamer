<!-- A. Command Bar -->
<div class="space-y-4">
  <div class="flex items-center gap-3">
    <!-- LQL Tag + Query Input -->
    <div class="flex items-center flex-1 bg-white border border-[#E2E8F0] rounded-lg overflow-hidden">
      <span class="font-body text-[12px] font-medium text-on-surface-variant bg-surface-container px-3 py-3 border-r border-[#E2E8F0]">LQL</span>
      <input class="flex-1 px-4 py-3 font-code text-[13px] text-on-surface focus:outline-none placeholder-on-surface-variant/50" value="service='payment-gateway' AND level='critical' | parse jso" type="text" />
      <button class="p-3 text-on-surface-variant/50 hover:text-secondary-container transition-colors">
        <span class="material-symbols-outlined text-[18px]">save</span>
      </button>
    </div>

    <!-- Run Query Button -->
    <button class="px-6 py-3 bg-secondary-container text-white font-body text-[14px] font-semibold rounded-lg hover:brightness-110 transition-all flex-shrink-0">
      RUN QUERY
    </button>

    <!-- Timeframe Picker -->
    <div class="flex items-center gap-2 px-4 py-3 bg-white border border-[#E2E8F0] rounded-lg cursor-pointer flex-shrink-0">
      <span class="material-symbols-outlined text-[18px] text-on-surface-variant">schedule</span>
      <span class="font-body text-[13px] text-on-surface font-medium">Last 15m</span>
      <span class="material-symbols-outlined text-[16px] text-on-surface-variant">expand_more</span>
    </div>
  </div>

  <!-- B. Recent Searches Pill Bar -->
  <div class="flex items-center gap-2">
    <span class="font-body text-[12px] text-on-surface-variant font-medium uppercase tracking-wider flex-shrink-0">RECENT:</span>
    <div class="flex items-center gap-2 flex-wrap">
      <span class="px-3 py-1.5 bg-white border border-[#E2E8F0] rounded-full font-code text-[12px] text-on-surface-variant cursor-pointer hover:border-secondary-container hover:text-secondary-container transition-colors">status=500</span>
      <span class="px-3 py-1.5 bg-white border border-[#E2E8F0] rounded-full font-code text-[12px] text-on-surface-variant cursor-pointer hover:border-secondary-container hover:text-secondary-container transition-colors">latency > 200ms</span>
      <span class="px-3 py-1.5 bg-white border border-[#E2E8F0] rounded-full font-code text-[12px] text-on-surface-variant cursor-pointer hover:border-secondary-container hover:text-secondary-container transition-colors">host:prod-worker-01</span>
    </div>
  </div>
</div>

<!-- C. KPI Summary Cards (4-Column Grid) -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

  <!-- Card 1: TOTAL EVENTS -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">TOTAL EVENTS</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-on-surface mb-3">1,204,551</div>
    <!-- 7-bar mini histogram -->
    <div class="h-8 flex items-end gap-[3px]">
      <div class="flex-1 bg-secondary-container/30 h-[30%] rounded-sm"></div>
      <div class="flex-1 bg-secondary-container/30 h-[45%] rounded-sm"></div>
      <div class="flex-1 bg-secondary-container/30 h-[60%] rounded-sm"></div>
      <div class="flex-1 bg-secondary-container/50 h-[75%] rounded-sm"></div>
      <div class="flex-1 bg-secondary-container/60 h-[55%] rounded-sm"></div>
      <div class="flex-1 bg-secondary-container/70 h-[80%] rounded-sm"></div>
      <div class="flex-1 bg-secondary-container/80 h-[65%] rounded-sm"></div>
    </div>
  </div>

  <!-- Card 2: ERROR RATE -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">ERROR RATE</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-error mb-3">0.02%</div>
    <div class="bg-error/10 rounded px-3 py-2">
      <span class="font-body text-[12px] font-medium text-error">Healthy</span>
    </div>
  </div>

  <!-- Card 3: P99 LATENCY -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">P99 LATENCY</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-secondary mb-3">142ms</div>
    <!-- Horizontal bar tracker ~75% -->
    <div class="h-[6px] bg-[#E2E8F0] w-full overflow-hidden rounded">
      <div class="bg-secondary h-full w-[75%] rounded"></div>
    </div>
  </div>

  <!-- Card 4: INDEXED NODES -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">INDEXED NODES</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-on-surface mb-3">24/24</div>
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-secondary-container"></span>
      <span class="font-body text-[12px] text-on-surface-variant">All clusters operational</span>
    </div>
  </div>
</div>

<!-- D. Structured Log Streams Data Table -->
<div class="bg-white border border-[#E2E8F0] rounded-lg overflow-hidden">
  <!-- Table Header -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3 bg-surface-container border-b border-[#E2E8F0]">
    <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">TIMESTAMP</span>
    <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">LEVEL</span>
    <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">SERVICE</span>
    <span class="font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">MESSAGE</span>
  </div>

  <!-- Row 1: CRITICAL -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3.5 border-b border-[#F1F5F9] hover:bg-surface-container/30 transition-colors">
    <span class="font-code text-[13px] text-on-surface">2023-11-24 14:02:11.452</span>
    <span class="px-2.5 py-1 bg-error/10 text-error font-body text-[12px] font-semibold rounded-full inline-block text-center w-fit">CRITICAL</span>
    <span class="font-code text-[13px] text-[#6f3721]">payment-gateway</span>
    <span class="font-body text-[13px] text-on-surface truncate">Failed to process transaction ID #4421 - Connection timeout to upstream ...</span>
  </div>

  <!-- Row 2: INFO -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3.5 border-b border-[#F1F5F9] hover:bg-surface-container/30 transition-colors">
    <span class="font-code text-[13px] text-on-surface">2023-11-24 14:02:10.981</span>
    <span class="px-2.5 py-1 bg-blue-50 text-secondary font-body text-[12px] font-semibold rounded-full inline-block text-center w-fit">INFO</span>
    <span class="font-code text-[13px] text-[#6f3721]">auth-api</span>
    <span class="font-body text-[13px] text-on-surface truncate">User session established for UID: 9982</span>
