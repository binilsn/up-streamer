<!-- A. Command Bar -->
<%= form_tag explorer_path, method: :get, class: "space-y-4", data: { controller: "search-help", turbo: false } do %>
  <%= hidden_field_tag :service, params[:service] if params[:service].present? && params[:service] != "all" %>
  <div class="flex items-center gap-3">
    <div class="flex items-center flex-1 border border-[#E2E8F0] rounded-lg overflow-hidden focus-within:border-secondary-container transition-colors">
      <%= text_field_tag :q, @query, class: "flex-1 px-4 py-3 font-code text-[13px] text-on-surface bg-white border-0 focus:outline-none focus:ring-0 placeholder-on-surface-variant/50", placeholder: "level:error host:web-01 status:500 duration:>200 \"timeout\"" %>
      <button type="button" data-action="click->search-help#show" class="px-3 py-3 bg-white border-l border-[#E2E8F0] hover:bg-surface-container transition-colors flex-shrink-0 cursor-pointer">
        <span class="material-symbols-outlined text-[18px] text-on-surface-variant">help_outline</span>
      </button>
    </div>

    <%= submit_tag "SEARCH", class: "px-6 py-3 bg-secondary-container text-white font-body text-[14px] font-semibold rounded-lg hover:brightness-110 transition-all flex-shrink-0 cursor-pointer" %>
  </div>

  <!-- Search Help Dialog -->
  <dialog data-search-help-target="dialog" data-action="keydown->search-help#keydown" class="rounded-xl border border-[#E2E8F0] shadow-2xl p-0 max-w-2xl w-[90vw] backdrop:bg-black/20 mx-auto my-auto fixed inset-0">
    <div class="p-6">
      <div class="flex items-center justify-between mb-6">
        <div>
          <h2 class="font-headline text-[20px] font-bold text-on-surface">Search Syntax</h2>
          <p class="font-body text-[13px] text-on-surface-variant mt-1">Filter logs using structured field:value expressions in the search bar.</p>
        </div>
        <button type="button" data-action="search-help#close" class="p-2 hover:bg-surface-container rounded-lg transition-colors cursor-pointer">
          <span class="material-symbols-outlined text-[20px] text-on-surface-variant">close</span>
        </button>
      </div>

      <div class="grid grid-cols-2 gap-2">
        <% help_items = [
          { field: "level", syntax: "level:error", desc: "Filter by log level" },
          { field: "service", syntax: "service:api", desc: "Filter by service name" },
          { field: "host", syntax: "host:web-01", desc: "Filter by hostname" },
          { field: "message", syntax: 'message:"timeout"', desc: "Search log message" },
          { field: "error_code", syntax: "error_code:ERR_500", desc: "Filter by error code" },
          { field: "status", syntax: "status:500", desc: "Filter by HTTP status" },
          { field: "env", syntax: "env:production", desc: "Filter by environment" },
          { field: "path", syntax: "path:/api/users", desc: "Filter by request path" },
          { field: "duration", syntax: "duration:>500", desc: "Filter by duration (>, <, >=, <=)" },
          { field: "trace_id", syntax: "trace_id:abc123", desc: "Filter by trace ID" },
          { field: "request_id", syntax: "request_id:req_001", desc: "Filter by request ID" },
          { field: "tag", syntax: "tag:payments", desc: "Filter by metadata tag" },
        ] %>
        <% help_items.each do |item| %>
          <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-container/30 border border-[#E2E8F0]">
            <code class="font-code text-[12px] font-semibold text-secondary-container whitespace-nowrap"><%= item[:syntax] %></code>
            <div>
              <span class="font-body text-[12px] font-medium text-on-surface"><%= item[:field] %></span>
              <p class="font-body text-[11px] text-on-surface-variant"><%= item[:desc] %></p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-6 p-4 bg-surface-container/30 rounded-lg border border-[#E2E8F0]">
        <p class="font-body text-[12px] text-on-surface-variant">
          <span class="font-semibold text-on-surface">Combine filters:</span>
          Separate multiple filters with spaces.
          Regular text without a field prefix searches log messages.
        </p>
      </div>

      <div class="mt-4 text-right">
        <button type="button" data-action="search-help#close" class="px-4 py-2 bg-secondary-container text-white font-body text-[13px] font-semibold rounded-lg hover:brightness-110 transition-colors cursor-pointer">
          Done
        </button>
      </div>
    </div>
  </dialog>

  <!-- Active Structured Filters -->
  <% if @structured_filters&.any? %>
    <div class="flex items-center gap-2 flex-wrap">
      <span class="font-body text-[12px] text-on-surface-variant font-medium uppercase tracking-wider flex-shrink-0">FILTERS:</span>
      <% @structured_filters.each do |filter| %>
        <% display = filter.operator == "=" ? "#{filter.field}:#{filter.value}" : "#{filter.field}:#{filter.operator}#{filter.value}" %>
        <%# Remove this filter from the query and rebuild %>
        <% new_q = remove_filter_from_query(params[:q], filter) %>
        <%= link_to explorer_path(request.query_parameters.merge(q: new_q.presence)), class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary-container/10 border border-secondary-container/30 rounded-full font-code text-[12px] text-secondary-container hover:bg-secondary-container/20 transition-colors group" do %>
          <span><%= display %></span>
          <span class="material-symbols-outlined text-[14px] opacity-60 group-hover:opacity-100 transition-opacity">close</span>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <div class="flex items-center gap-2">
    <span class="font-body text-[12px] text-on-surface-variant font-medium uppercase tracking-wider flex-shrink-0">LEVEL:</span>
    <div class="flex gap-2 flex-wrap">
      <% [ "all", "debug", "info", "warn", "error", "critical" ].each do |level| %>
        <% base = { q: params[:q], service: params[:service] }.compact %>
        <% url = level == "all" ? explorer_path(base) : explorer_path(base.merge(level: level)) %>
        <% active = level == "all" ? params[:level].blank? : params[:level] == level %>
        <%= link_to url, class: "px-3 py-1.5 bg-white border border-[#E2E8F0] rounded-full font-code text-[12px] #{active ? 'border-secondary-container text-secondary-container' : 'text-on-surface-variant hover:border-secondary-container hover:text-secondary-container'} transition-colors" do %>
          <%= level.humanize %>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<!-- C. KPI Summary Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">TOTAL EVENTS</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-on-surface mb-3"><%= number_with_delimiter(@total_events) %></div>
    <div class="h-8 flex items-end gap-[3px]">
      <% heights = [30, 45, 60, 75, 55, 80, 65] %>
      <% opacities = [0.3, 0.3, 0.3, 0.5, 0.6, 0.7, 0.8] %>
      <% 7.times do |i| %>
        <div class="flex-1 bg-secondary-container rounded-sm" style="height: <%= heights[i] %>%; opacity: <%= opacities[i] %>;"></div>
      <% end %>
    </div>
  </div>

  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">ERROR RATE</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-error mb-3"><%= @error_rate %>%</div>
    <% if @error_rate < 1 %>
      <div class="bg-green-50 rounded px-3 py-2">
        <span class="font-body text-[12px] font-medium text-green-700">Healthy</span>
      </div>
    <% else %>
      <div class="bg-red-50 rounded px-3 py-2">
        <span class="font-body text-[12px] font-medium text-red-700">Attention needed</span>
      </div>
    <% end %>
  </div>

  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">P99 LATENCY</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-secondary mb-3"><%= number_with_delimiter(@p99_latency) %>ms</div>
    <% bar_width = [(@p99_latency / 1000.0 * 100).round, 100].min %>
    <div class="h-[6px] bg-[#E2E8F0] w-full overflow-hidden rounded">
      <div class="bg-secondary h-full rounded" style="width: <%= bar_width %>%"></div>
    </div>
  </div>

  <div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
    <div class="flex justify-between items-start mb-3">
      <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">SERVICES</span>
    </div>
    <div class="font-headline text-[28px] font-bold text-on-surface mb-3"><%= @service_count %></div>
    <div class="flex items-center gap-2">
      <span class="w-2 h-2 rounded-full bg-secondary-container"></span>
      <span class="font-body text-[12px] text-on-surface-variant"><%= pluralize(@service_count, 'service') %> registered</span>
    </div>
  </div>
</div>

<!-- Last Log Received -->
<div class="bg-white border border-[#E2E8F0] rounded-lg p-6">
  <div class="flex justify-between items-start mb-3">
    <span class="font-body text-[12px] font-medium uppercase tracking-wider text-on-surface-variant">LAST LOG RECEIVED</span>
    <span class="material-symbols-outlined text-[18px] text-on-surface-variant">schedule</span>
  </div>
  <% if @last_log %>
    <div class="font-headline text-[22px] font-bold text-on-surface mb-2"><%= time_ago_in_words(@last_log.timestamp) %> ago</div>
    <div class="flex items-center gap-3 font-body text-[13px] text-on-surface-variant">
      <span class="px-2 py-0.5 rounded-full text-[11px] font-semibold
        <%= case @last_log.level
           when 'critical' then 'bg-error/10 text-error'
           when 'error' then 'bg-error/10 text-error'
           when 'warn' then 'bg-amber-50 text-amber-700'
           when 'debug' then 'bg-surface-container text-on-surface-variant'
           else 'bg-blue-50 text-secondary'
           end %>"><%= @last_log.level.upcase %></span>
      <span><%= @last_log.service.name %></span>
      <span class="text-outline">|</span>
      <span class="truncate"><%= @last_log.message %></span>
    </div>
  <% else %>
    <p class="font-body text-[14px] text-on-surface-variant">No logs received yet.</p>
  <% end %>
</div>

<!-- D. Structured Log Streams Data Table -->
<div class="bg-white border border-[#E2E8F0] rounded-lg overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="bg-surface-container border-b border-[#E2E8F0]">
        <th class="px-6 py-3 text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">TIMESTAMP</th>
        <th class="px-6 py-3 text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">LEVEL</th>
        <th class="px-6 py-3 text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">SERVICE</th>
        <th class="px-6 py-3 text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant">MESSAGE</th>
      </tr>
    </thead>
    <tbody>
      <% if @logs.any? %>
        <% @logs.each_with_index do |log, idx| %>
          <% border = idx < @logs.length - 1 ? "border-b border-[#F1F5F9]" : "" %>
          <% level_class = case log.level
             when "critical" then "bg-error/10 text-error"
             when "error" then "bg-error/10 text-error"
             when "warn" then "bg-amber-50 text-amber-700"
             when "debug" then "bg-surface-container text-on-surface-variant"
             else "bg-blue-50 text-secondary"
             end %>
          <tr class="<%= border %> hover:bg-surface-container/30 transition-colors">
            <td class="px-6 py-3.5 font-code text-[13px] text-on-surface"><%= log.timestamp.strftime("%Y-%m-%d %H:%M:%S.%L") %></td>
            <td class="px-6 py-3.5">
              <span class="px-2.5 py-1 <%= level_class %> font-body text-[12px] font-semibold rounded-full inline-block"><%= log.level.upcase %></span>
            </td>
            <td class="px-6 py-3.5 font-code text-[13px] text-[#6f3721]"><%= log.service.name %></td>
            <td class="px-6 py-3.5 font-body text-[13px] text-on-surface truncate max-w-0"><%= log.message %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="4" class="px-6 py-8 text-center font-body text-[14px] text-on-surface-variant">No logs found.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<!-- Pagination -->
<div class="flex items-center justify-between pt-4">
  <span class="font-body text-[13px] text-on-surface-variant">Page <%= @pagy.page %> of <%= [@pagy.pages, 1].max %> (<%= @pagy.count %> total)</span>
  <div class="flex items-center gap-2">
    <% base_params = { q: params[:q], level: params[:level], service: params[:service] }.compact %>
    <% if @pagy.prev %>
      <%= link_to explorer_path(base_params.merge(page: @pagy.prev)), class: "px-4 py-2 bg-white border border-[#E2E8F0] rounded-lg font-body text-[13px] text-on-surface hover:bg-surface-container transition-colors" do %>
        <span class="material-symbols-outlined text-[16px]">chevron_left</span>
      <% end %>
    <% end %>
    <% if @pagy.pages > 0 %>
      <% ([@pagy.page - 2, 1].max..[@pagy.page + 2, @pagy.pages].min).each do |p| %>
        <%= link_to explorer_path(base_params.merge(page: p)), class: "px-3 py-2 #{p == @pagy.page ? 'bg-secondary-container text-white' : 'bg-white border border-[#E2E8F0] text-on-surface hover:bg-surface-container'} rounded-lg font-body text-[13px] transition-colors" do %>
          <%= p %>
        <% end %>
      <% end %>
    <% end %>
    <% if @pagy.next %>
      <%= link_to explorer_path(base_params.merge(page: @pagy.next)), class: "px-4 py-2 bg-white border border-[#E2E8F0] rounded-lg font-body text-[13px] text-on-surface hover:bg-surface-container transition-colors" do %>
        <span class="material-symbols-outlined text-[16px]">chevron_right</span>
      <% end %>
    <% end %>
  </div>
</div>
