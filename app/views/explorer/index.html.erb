  <!-- Row 3: WARN -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3.5 border-b border-[#F1F5F9] hover:bg-surface-container/30 transition-colors">
    <span class="font-code text-[13px] text-on-surface">2023-11-24 14:02:08.122</span>
    <span class="px-2.5 py-1 bg-amber-50 text-amber-700 font-body text-[12px] font-semibold rounded-full inline-block text-center w-fit">WARN</span>
    <span class="font-code text-[13px] text-[#6f3721]">inventory-svc</span>
    <span class="font-body text-[13px] text-on-surface truncate">Slow query detected on collection 'skus' - Duration 450ms</span>
  </div>

  <!-- Row 4: INFO -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3.5 border-b border-[#F1F5F9] hover:bg-surface-container/30 transition-colors">
    <span class="font-code text-[13px] text-on-surface">2023-11-24 14:02:05.556</span>
    <span class="px-2.5 py-1 bg-blue-50 text-secondary font-body text-[12px] font-semibold rounded-full inline-block text-center w-fit">INFO</span>
    <span class="font-code text-[13px] text-[#6f3721]">worker-pool</span>
    <span class="font-body text-[13px] text-on-surface truncate">Scaling worker nodes: +2 (total 14)</span>
  </div>

  <!-- Row 5: DEBUG -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3.5 border-b border-[#F1F5F9] hover:bg-surface-container/30 transition-colors">
    <span class="font-code text-[13px] text-on-surface">2023-11-24 14:02:02.109</span>
    <span class="px-2.5 py-1 bg-surface-container text-on-surface-variant font-body text-[12px] font-semibold rounded-full inline-block text-center w-fit">DEBUG</span>
    <span class="font-code text-[13px] text-[#6f3721]">cache-mgr</span>
    <span class="font-body text-[13px] text-on-surface truncate">Cache miss for key: product_page_metadata_v2_992</span>
  </div>

  <!-- Row 6: INFO -->
  <div class="grid grid-cols-[140px_100px_1fr_2fr] gap-4 px-6 py-3.5 hover:bg-surface-container/30 transition-colors">
    <span class="font-code text-[13px] text-on-surface">2023-11-24 14:02:00.001</span>
    <span class="px-2.5 py-1 bg-blue-50 text-secondary font-body text-[12px] font-semibold rounded-full inline-block text-center w-fit">INFO</span>
    <span class="font-code text-[13px] text-[#6f3721]">scheduler</span>
    <span class="font-body text-[13px] text-on-surface truncate">Completed cron job: daily-cleanup-tasks</span>
