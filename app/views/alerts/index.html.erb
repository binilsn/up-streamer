<div class="space-y-6">

  <!-- Header -->
  <div class="flex justify-between items-end mb-2">
    <div>
      <h2 class="font-headline text-[32px] font-bold tracking-tight text-on-surface">Alerts</h2>
      <p class="font-body text-[14px] text-on-surface-variant mt-1">
        <span class="text-error font-semibold"><%= @active_count %> active</span>
        <span class="text-on-surface-variant mx-2">|</span>
        <%= @total_count %> total
      </p>
    </div>
  </div>

  <!-- Severity / Status Summary Pills -->
  <div class="flex flex-wrap items-center gap-3">
    <span class="font-body text-[12px] font-medium text-on-surface-variant uppercase tracking-wider">SEVERITY:</span>
    <% %w[critical high medium low].each do |sev| %>
      <% count = @severity_counts[sev] || 0 %>
      <% sev_class = case sev
                     when "critical" then "bg-red-100 text-red-800 border-red-200"
                     when "high" then "bg-orange-100 text-orange-800 border-orange-200"
                     when "medium" then "bg-amber-100 text-amber-800 border-amber-200"
                     when "low" then "bg-blue-100 text-blue-800 border-blue-200"
                     end %>
      <%= link_to alerts_path(severity: sev, status: params[:status]),
          class: "px-3 py-1.5 font-body text-[12px] font-medium rounded-full border #{sev_class} #{'ring-2 ring-offset-1 ring-secondary' if params[:severity] == sev}" do %>
        <%= sev.upcase %> <%= "(#{count})" if count > 0 %>
      <% end %>
    <% end %>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <span class="font-body text-[12px] font-medium text-on-surface-variant uppercase tracking-wider">STATUS:</span>
    <%= link_to alerts_path(status: nil, severity: params[:severity]),
        class: "px-3 py-1.5 font-body text-[12px] font-medium rounded-full border border-outline-variant #{params[:status].blank? ? 'bg-white shadow-sm text-on-surface' : 'text-on-surface-variant hover:text-on-surface'}" do %>
      ALL
    <% end %>
    <% %w[active acknowledged resolved].each do |status| %>
      <% count = @status_counts[status] || 0 %>
      <%= link_to alerts_path(status: status, severity: params[:severity]),
          class: "px-3 py-1.5 font-body text-[12px] font-medium rounded-full border border-outline-variant #{params[:status] == status ? 'bg-white shadow-sm text-on-surface' : 'text-on-surface-variant hover:text-on-surface'}" do %>
        <%= status.upcase %> <%= "(#{count})" if count > 0 %>
      <% end %>
    <% end %>
  </div>

  <!-- Alerts Table -->
  <div class="bg-white border border-[#E2E8F0] rounded-lg overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="bg-surface-container border-b border-[#E2E8F0]">
            <th class="text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant px-6 py-3">Severity</th>
            <th class="text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant px-6 py-3">Title</th>
            <th class="text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant px-6 py-3">Service</th>
            <th class="text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant px-6 py-3">Status</th>
            <th class="text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant px-6 py-3">Triggered</th>
            <th class="text-left font-body text-[11px] font-medium uppercase tracking-wider text-on-surface-variant px-6 py-3">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if @alerts.empty? %>
            <tr>
              <td colspan="6" class="px-6 py-12 text-center font-body text-[13px] text-on-surface-variant">
                No alerts found.
              </td>
            </tr>
          <% else %>
            <% @alerts.each do |alert| %>
              <tr class="border-b border-[#F1F5F9] hover:bg-surface-container/30 transition-colors">
                <td class="px-6 py-4">
                  <% sev_badge = case alert.severity
                     when "critical" then "bg-red-100 text-red-800"
                     when "high" then "bg-orange-100 text-orange-800"
                     when "medium" then "bg-amber-100 text-amber-800"
                     when "low" then "bg-blue-100 text-blue-800"
                     end %>
                  <span class="px-2.5 py-1 font-body text-[11px] font-semibold rounded-full <%= sev_badge %>"><%= alert.severity.upcase %></span>
                </td>
                <td class="px-6 py-4">
                  <div class="font-body text-[13px] font-medium text-on-surface"><%= alert.title %></div>
                  <% if alert.description.present? %>
                    <div class="font-body text-[11px] text-on-surface-variant mt-0.5"><%= alert.description.truncate(120) %></div>
                  <% end %>
                </td>
                <td class="px-6 py-4 font-body text-[13px] text-on-surface"><%= alert.service&.name || "—" %></td>
                <td class="px-6 py-4">
                  <% status_badge = case alert.status
                     when "active" then "bg-error/10 text-error"
                     when "acknowledged" then "bg-amber-50 text-amber-700"
                     when "resolved" then "bg-green-50 text-green-700"
                     end %>
                  <span class="px-2.5 py-1 font-body text-[11px] font-semibold rounded-full <%= status_badge %>"><%= alert.status.upcase %></span>
                </td>
                <td class="px-6 py-4 font-code text-[12px] text-on-surface-variant">
                  <%= alert.triggered_at.strftime("%Y-%m-%d %H:%M:%S") %>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-2">
                    <% if alert.status == "active" %>
                      <%= button_to acknowledge_alert_path(alert), method: :post,
                          class: "px-3 py-1.5 text-[11px] font-medium font-body bg-amber-50 text-amber-700 border border-amber-200 rounded hover:bg-amber-100 transition-colors" do %>
                        Acknowledge
                      <% end %>
                    <% end %>
                    <% if alert.status != "resolved" %>
                      <%= button_to resolve_alert_path(alert), method: :post,
                          class: "px-3 py-1.5 text-[11px] font-medium font-body bg-green-50 text-green-700 border border-green-200 rounded hover:bg-green-100 transition-colors" do %>
                        Resolve
                      <% end %>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if @pagy.pages > 1 %>
      <div class="px-6 py-4 border-t border-[#E2E8F0] bg-surface-container/30">
        <div class="flex items-center justify-between">
          <div class="font-body text-[12px] text-on-surface-variant">
            Page <%= @pagy.page %> of <%= @pagy.pages %> (<%= @pagy.count %> total)
          </div>
          <div class="flex items-center gap-2">
            <% if @pagy.prev %>
              <%= link_to alerts_path(page: @pagy.prev, severity: params[:severity], status: params[:status]),
                  class: "px-3 py-1.5 text-[12px] font-medium font-body bg-white border border-outline-variant rounded hover:bg-surface-container transition-colors" do %>
                ← Prev
              <% end %>
            <% end %>
            <% if @pagy.next %>
              <%= link_to alerts_path(page: @pagy.next, severity: params[:severity], status: params[:status]),
                  class: "px-3 py-1.5 text-[12px] font-medium font-body bg-white border border-outline-variant rounded hover:bg-surface-container transition-colors" do %>
                Next →
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
