<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Up Streamer — Sign In" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Hanken+Grotesk:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#F9FAFC] text-on-surface font-body min-h-screen flex items-center justify-center p-8">
    <div class="w-full max-w-sm">
      <!-- Logo -->
      <div class="text-center mb-8">
        <h1 class="font-headline text-[24px] font-semibold tracking-tight text-[#0A174C] uppercase">UP-STREAMER</h1>
        <p class="font-body text-[13px] text-[#45464F] mt-1">Log Management Console</p>
      </div>

      <!-- Flash -->
      <% if notice || alert %>
        <div class="flash-messages space-y-2 mb-6">
          <% if notice %>
            <div class="px-4 py-3 rounded bg-green-50 border border-green-200 text-green-800 text-[14px]"><%= notice %></div>
          <% end %>
          <% if alert %>
            <div class="px-4 py-3 rounded bg-red-50 border border-red-200 text-red-800 text-[14px]"><%= alert %></div>
          <% end %>
        </div>
      <% end %>

      <!-- Card -->
      <div class="bg-white border border-[#E2E8F0] rounded-lg p-8">
        <%= yield %>
      </div>
    </div>
  </body>
</html>
