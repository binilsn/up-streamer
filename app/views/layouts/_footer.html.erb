<footer data-controller="footer" class="flex items-center justify-between w-full py-2.5 px-8 bg-surface-container border-t border-outline-variant text-[12px] flex-shrink-0">
  <!-- Left: Ingestion Rates -->
  <div class="flex items-center gap-2">
    <span class="w-2 h-2 rounded-full bg-secondary-container animate-pulse"></span>
    <span class="font-body font-medium text-on-surface-variant">INGESTION RATE: <span id="footer-ingestion-rate" class="font-code">0.0 KB/S</span></span>
    <span class="text-outline">|</span>
    <span class="font-code text-on-surface-variant">EVENTS/SEC: <span id="footer-events-per-sec" class="font-code">0</span></span>
  </div>
  <!-- Right: System State Parameters -->
  <div class="flex items-center gap-2 font-code text-on-surface-variant">
    <span>MEMORY: <span id="footer-memory-used">0.0</span> GB / <span id="footer-memory-total">0.0</span> GB</span>
    <span class="text-outline">|</span>
    <span class="material-symbols-outlined text-[14px] text-secondary-container">memory</span>
    <span>CPU: <span id="footer-cpu-pct">0.0</span>%</span>
    <span class="text-outline">|</span>
    <span class="material-symbols-outlined text-[14px] text-green-600">rocket_launch</span>
    <span>UP: <span id="footer-uptime">0h 0m</span></span>
  </div>
</footer>
