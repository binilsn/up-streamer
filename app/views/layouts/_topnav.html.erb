<header class="sticky top-0 z-10 flex items-center w-full py-4 px-8 gap-4 bg-primary-container">
  <!-- Service Selector -->
  <div class="flex items-center gap-2 flex-shrink-0">
    <span class="font-body text-[11px] text-white/50 uppercase tracking-wider font-medium">Service</span>
    <%= form_tag request.path, method: :get, class: "flex items-center", data: { turbo_action: "replace" } do %>
      <% # Preserve other params %>
      <% params.except(:service, :controller, :action).each do |key, value| %>
        <%= hidden_field_tag key, value %>
      <% end %>
      <%= select_tag :service,
          options_for_select([["All Services", ""]] + all_services.map { |s| [s, s] }, params[:service]),
          class: "bg-white border border-white/30 rounded px-3 py-1.5 font-body text-[13px] text-primary-container font-medium focus:outline-none focus:ring-1 focus:ring-white cursor-pointer min-w-[140px]",
          onchange: "this.form.submit()" %>
    <% end %>
  </div>

  <!-- Spacer -->
  <div class="flex-1"></div>

  <!-- Right: Icons -->
  <div class="flex items-center gap-2 flex-shrink-0">
    <button class="p-2.5 text-white/70 hover:bg-white/10 hover:text-white transition-colors duration-150 rounded">
      <span class="material-symbols-outlined text-[20px]">notifications</span>
    </button>
    <button class="p-2 text-white/70 hover:bg-white/10 hover:text-white transition-colors duration-150 rounded">
      <span class="material-symbols-outlined text-[20px]">terminal</span>
    </button>
    <button class="p-2 text-white/70 hover:bg-white/10 hover:text-white transition-colors duration-150 rounded">
      <span class="material-symbols-outlined text-[20px]">settings</span>
    </button>
    <!-- User Avatar -->
    <div class="w-8 h-8 rounded-full bg-secondary text-white flex items-center justify-center font-bold text-xs flex-shrink-0 ml-1">
      <span class="material-symbols-outlined text-[16px]">person</span>
    </div>
  </div>
</header>
