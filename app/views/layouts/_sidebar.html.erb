<% active_class = "flex items-center gap-3 px-4 py-2.5 bg-[#16245C] text-white border-l-[4px] border-secondary-container font-semibold rounded-r" %>
<% inactive_class = "flex items-center gap-3 px-4 py-2.5 text-white/70 font-medium hover:bg-white/5 hover:text-white transition-colors duration-150 rounded-r" %>

<aside data-sidebar-target="sidebar"
     class="sidebar-fixed hidden md:flex flex-col h-screen py-4 space-y-2 bg-primary-container flex-shrink-0 transition-all duration-200">

  <!-- Logo + Toggle -->
  <div class="px-6 mb-6 overflow-hidden flex items-center justify-between">
    <h1 data-sidebar-target="logoText" class="font-headline text-[20px] font-semibold tracking-tight text-white uppercase whitespace-nowrap">SENTINEL_LOG</h1>
    <button data-action="click->sidebar#toggle"
            class="p-1 text-white/50 hover:text-white transition-colors duration-150 rounded flex-shrink-0">
      <span class="material-symbols-outlined text-[20px]">menu</span>
    </button>
  </div>

  <!-- User Context Header -->
  <div data-sidebar-target="userInfo" class="flex items-center gap-3 px-4 py-2.5 mb-2 mx-2 overflow-hidden">
    <div class="w-8 h-8 rounded bg-secondary/20 text-secondary-container flex items-center justify-center flex-shrink-0">
      <span class="material-symbols-outlined text-[18px]">hub</span>
    </div>
    <div class="overflow-hidden">
      <p class="font-body text-[14px] text-white font-semibold truncate whitespace-nowrap">System Admin</p>
      <p class="font-body text-[11px] text-blue-300/70 truncate whitespace-nowrap uppercase tracking-wider">Precision Cluster A</p>
    </div>
  </div>

  <!-- Primary Navigation -->
  <nav class="space-y-1 px-2">
    <% svc = params[:service].presence %>
    <%= link_to root_path(service: svc), class: current_page?(root_path) ? active_class : inactive_class do %>
      <span class="material-symbols-outlined text-[20px] flex-shrink-0">dashboard</span>
      <span data-sidebar-target="navText" class="font-body text-[14px] whitespace-nowrap">Dashboard</span>
    <% end %>
    <%= link_to live_stream_path(service: svc), class: current_page?(live_stream_path) ? active_class : inactive_class do %>
      <span class="material-symbols-outlined text-[20px] flex-shrink-0">reorder</span>
      <span data-sidebar-target="navText" class="font-body text-[14px] whitespace-nowrap">Live Stream</span>
    <% end %>
    <%= link_to explorer_path(service: svc), class: current_page?(explorer_path) ? active_class : inactive_class do %>
      <span class="material-symbols-outlined text-[20px] flex-shrink-0">search_check</span>
      <span data-sidebar-target="navText" class="font-body text-[14px] whitespace-nowrap">Explorer</span>
    <% end %>
    <%= link_to alerts_path(service: svc), class: current_page?(alerts_path) ? active_class : inactive_class do %>
      <span class="material-symbols-outlined text-[20px] flex-shrink-0">notifications_active</span>
      <span data-sidebar-target="navText" class="font-body text-[14px] whitespace-nowrap">Alerts</span>
    <% end %>
  </nav>

  <!-- Bottom Actions -->
  <div class="px-2 mt-auto border-t border-white/10 pt-4 space-y-1">
    <%= link_to services_path, class: "flex items-center gap-3 px-4 py-2.5 text-white/70 font-medium hover:bg-white/5 hover:text-white transition-colors duration-150 rounded" do %>
      <span class="material-symbols-outlined text-[20px] flex-shrink-0">api</span>
      <span data-sidebar-target="label" class="font-body text-[14px] whitespace-nowrap">Services</span>
    <% end %>
    <%= link_to doc_path, class: "flex items-center gap-3 px-4 py-2.5 text-white/70 font-medium hover:bg-white/5 hover:text-white transition-colors duration-150 rounded" do %>
      <span class="material-symbols-outlined text-[20px] flex-shrink-0">description</span>
      <span data-sidebar-target="label" class="font-body text-[14px] whitespace-nowrap">Doc</span>
    <% end %>
  </div>
</aside>
