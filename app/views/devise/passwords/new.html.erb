<h2 class="font-headline text-[18px] font-semibold text-[#1B1B1F] mb-6">Forgot your password?</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, data: { turbo: false } }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="mb-5">
    <%= f.label :email, class: "block text-[13px] font-semibold text-[#45464F] uppercase tracking-wider mb-1.5" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1 text-sm w-full px-3 py-2 bg-white border border-[#E2E8F0] rounded text-[#1B1B1F] focus:outline-none focus:ring-1 focus:ring-[#0052FF] focus:border-[#0052FF]" %>
  </div>

  <div class="actions">
    <%= f.submit "Send Reset Instructions", class: "w-full px-8 py-2.5 cursor-pointer font-semibold text-sm rounded text-white bg-[#0052FF] hover:bg-[#003EC6] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0052FF] transition-colors duration-150" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
